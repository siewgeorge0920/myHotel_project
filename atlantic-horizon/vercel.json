{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "cd server && npm install",
  "framework": "vite",
  "functions": {
    "server/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "src": "/api/:path*",
      "dest": "/server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/index.html"
    }
  ]
}